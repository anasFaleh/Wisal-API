# Copy this file to .env and fill in the values.
# Never commit the real .env file — it is gitignored.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET="replace-with-64-byte-random-hex"
JWT_REFRESH_SECRET="replace-with-64-byte-random-hex"

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV="development"        # development | production | test
PORT=3000
CORS_ORIGIN="http://localhost:3000"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_TTL=300

# ── Other ─────────────────────────────────────────────────────────────────────
SERVER_URL="https://your-domain.com"
